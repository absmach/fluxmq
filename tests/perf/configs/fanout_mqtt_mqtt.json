{
  "name": "topic-fanout-mqtt-mqtt",
  "description": "Config-driven topic fan-out: MQTT publishers to MQTT subscribers across many topics.",
  "pattern": "fanout",
  "flow": "mqtt-mqtt",
  "topic": "perf/topic/config/fanout/mqtt-mqtt/{run_id}",
  "qos": 1,
  "topic_count": 48,
  "publishers": 200,
  "messages_per_publisher": 100,
  "publish_interval": "50ms",
  "subscribers": 200,
  "wildcard_subscribers": 20,
  "wildcard_patterns": [
    "{base}/t/+",
    "{base}/#"
  ],
  "drain_timeout": "30s",
  "payload_bytes": 4096
}
